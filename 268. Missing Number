class Solution(object):
    def missingNumber(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """

        Cout = []
        for i in range(len(nums) + 1):
            Cout.append(i)
            if Cout[i] not in nums:
                return(Cout[i])

                
