class Solution(object):
    def maxProfit(self, prices):
        """
        :type prices: List[int]
        :rtype: int
        """
        More_prices = 0
        Less_buy = 1000000
        for i in range(len(prices)): 
            if prices[i] < Less_buy:
                Less_buy = prices[i]
            else:
                if prices[i] - Less_buy > More_prices:
                    More_prices = prices[i] - Less_buy

        return(More_prices)           
                
